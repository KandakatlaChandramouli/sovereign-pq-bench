#!/usr/bin/env python3
"""Sovereign-Bench: one-command PQC evaluation."""
import argparse, subprocess, sys, os, json

REPO = '/workspaces/sovereign-pq-bench'
BUILD = f'{REPO}/build'

def run(cmd, cwd=REPO):
    subprocess.run(cmd, shell=True, cwd=cwd, check=True)

parser = argparse.ArgumentParser(prog='sovereign-bench')
parser.add_argument('--target', choices=['tls','vpn','iot','blockchain','all'], default='all')
parser.add_argument('--hardware', default='xeon')
parser.add_argument('--security-level', type=int, choices=[1,3,5], default=3)
parser.add_argument('--output', default='report')
args = parser.parse_args()

# Rebuild if necessary
os.makedirs(BUILD, exist_ok=True)
subprocess.run(f'cmake -B {BUILD} -DCMAKE_BUILD_TYPE=Release', shell=True)
subprocess.run(f'cmake --build {BUILD} -j$(nproc) --target gulf_bench hardware_bench', shell=True)

# Run benchmarks
subprocess.run(f'{BUILD}/gulf_bench', shell=True)
subprocess.run(f'{BUILD}/hardware_bench', shell=True)

# Generate figures
subprocess.run(f'python3 {REPO}/scripts/gulf_complete_visualizer.py', shell=True)
subprocess.run(f'python3 {REPO}/scripts/gulf_100_visualizer.py', shell=True)
subprocess.run(f'python3 {REPO}/scripts/pareto_frontiers.py', shell=True)
subprocess.run(f'python3 {REPO}/scripts/case_study_impact.py', shell=True)

# Compile recommendation based on hardware
recommendation = {
    'xeon': 'ML-DSA-44 (fastest, moderate size)',
    'arm': 'Falcon-512 (compact, lower memory)'
}
print(f'✅ Recommendation for {args.hardware}: {recommendation.get(args.hardware, "ML-DSA-44")}')
print(f'📊 Report generated in {REPO}/results/')
